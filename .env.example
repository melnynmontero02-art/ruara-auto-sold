# Google Analytics 4 — Measurement ID (formato G-XXXXXXXXXX)
# Crear en https://analytics.google.com → Admin → Flujos de datos → Web
NEXT_PUBLIC_GA_ID=

# Google Search Console — código de verificación del meta tag
# Crear propiedad en https://search.google.com/search-console → método "Etiqueta HTML"
# Pegar solo el valor del atributo content (sin el resto del tag)
GOOGLE_SITE_VERIFICATION=
